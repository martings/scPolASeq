manifest {
    name            = 'scPolASeq'
    author          = 'Codex scaffold'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
}

plugins {
    id 'nf-schema@2.2.1'
}

params {
    input                      = null
    genome_fasta               = null
    gtf                        = null
    known_polya                = null
    priming_blacklist          = null
    cell_metadata              = null
    cluster_assignments        = null
    cell_type_labels           = null
    outdir                     = 'results'
    run_mode                   = 'full'
    aligner                    = 'starsolo'
    protocol_mode              = '10x_3p'
    enable_internal_clustering = true
    grouping_levels            = 'cluster,cell_type,sample_condition_celltype'
    emit_group_bams            = false
    emit_bigwigs               = true
    publish_dir_mode           = 'copy'
    max_cpus                   = 8
    max_memory                 = '32 GB'
    max_time                   = '24 h'

    // ── APA detection parameters ──────────────────────────────────────────────
    apa_min_coverage                  = 5         // minimum read coverage at a candidate site
    apa_min_pdui_delta                = 0.2       // |ΔPDUI| threshold for APA significance
    apa_grouping_levels               = 'cluster,cell_type'  // comma-separated group levels
    apa_group_level                   = 'cluster' // primary level used for ML training/prediction
    enable_pas_reference_build        = true      // scaffold stage: build a contract-stable PAS reference artifact
    pas_reference_merge_distance      = 25        // bp distance used when collapsing PAS evidence into one reference site
    enable_sierra_quant               = true      // scaffold stage: emit Sierra-compatible quant tables
    enable_pas_scoring                = true      // scaffold stage: emit PAS scoring sidecar outputs

    // ── ML model parameters ───────────────────────────────────────────────────
    apa_model_type                    = 'random_forest'  // 'random_forest'|'xgboost'|'logistic_regression'
    enable_single_cell_apa_projection = false    // project group APA scores back to single cells

    // ── Container / Apptainer paths ───────────────────────────────────────────
    // Set to the directory holding pre-built scpolaseq-*.sif files.
    // Build them once with: bash containers/build.sh [--cache-dir <dir>]
    // Leave null to fall back to conda (default behaviour).
    apptainer_cache_dir = null
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    test                      { includeConfig 'conf/test.config'                     }
    test_pbmc1k               { includeConfig 'conf/test_pbmc1k.config'              }
    test_pbmc1k_deepthought   { includeConfig 'conf/test_pbmc1k_deepthought.config'  }
    docker                    { includeConfig 'conf/docker.config'                   }
    singularity               { includeConfig 'conf/singularity.config'              }
    apptainer                 { includeConfig 'conf/apptainer.config'                }
    local                     { includeConfig 'conf/local.config'                    }
    slurm                     { includeConfig 'conf/slurm.config'                    }
    deepthought               { includeConfig 'conf/deepthought.config'              }
}
