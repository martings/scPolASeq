Bootstrap: docker
From: mambaorg/micromamba:1.5.10-jammy

%labels
    maintainer  scPolASeq
    description "Alignment env: STAR 2.7.11b, samtools 1.21, pysam"
    env_source  envs/alignment.yml

%post
    micromamba install -y -n base \
        -c conda-forge -c bioconda \
        python=3.11 \
        "star=2.7.11b" \
        samtools=1.21 \
        pysam=0.22.1 && \
    micromamba clean --all -y

%environment
    export PATH=/opt/conda/bin:$PATH
    export MAMBA_NO_BANNER=1
