Bootstrap: docker
From: mambaorg/micromamba:1.5.10-jammy

%labels
    maintainer  scPolASeq
    description "Clustering env: scanpy, anndata, pandas, scipy, numpy"
    env_source  envs/clustering.yml

%post
    micromamba install -y -n base \
        -c conda-forge -c bioconda \
        python=3.11 \
        "scanpy>=1.10.3" \
        "anndata>=0.10.8" \
        "pandas>=2.2" \
        "scipy>=1.14" \
        "numpy>=2.0" && \
    micromamba clean --all -y

%environment
    export PATH=/opt/conda/bin:$PATH
    export MAMBA_NO_BANNER=1
