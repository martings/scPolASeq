/*
 * dengue_day1_deepthought.config
 *
 * Dengue scRNA-seq Day -1 pilot — E-MTAB-9467 (Arora et al. 2022)
 * Two patients: DF and DHF, 2 runs each (~5 k cells/sample after merging).
 * Chemistry: 10x Chromium 3' v2 (26 bp R1: 16 bp CB + 10 bp UMI).
 *
 * Usage:
 *   nextflow run main.nf \
 *     -profile deepthought,apptainer,dengue_day1_deepthought \
 *     -work-dir /scratch/users/fabro/nf_work \
 *     --outdir /scratch/users/fabro/scPolASeq_dengue/results/day1 \
 *     --apptainer_cache_dir /scratch/cache/apptainer
 *
 * NOTE — barcode whitelist:
 *   The 10x v2 whitelist (737K-august-2016.txt) is not staged.
 *   STARsolo will run with --soloCBwhitelist None and CellRanger2.2 knee-point
 *   filtering, which is acceptable for exploratory runs.
 *   To add it: download the file, set barcode_whitelist in the samplesheet,
 *   and it will be picked up automatically.
 */
params {

    // ── Input ──────────────────────────────────────────────────────────────
    input = "${projectDir}/tests/data/samplesheet_dengue_day1.csv"

    // ── Reference — GRCh38 (same build as pbmc1k) ─────────────────────────
    genome_fasta = '/scratch/data/reference/GRCh38/genome.fa'
    gtf          = '/scratch/data/reference/GRCh38/genes.gtf'

    // Reuse the index built for the pbmc1k run (same genome + GTF).
    prebuilt_star_index = '/scratch/results/scPolASeq/pbmc1k/reference/star_index'

    // ── polyA atlas ────────────────────────────────────────────────────────
    known_polya = '/scratch/data/polya_atlas/polyasite2_GRCh38.tsv'

    // ── No pre-supplied cell metadata: internal clustering ─────────────────
    cell_metadata       = null
    cluster_assignments = null
    cell_type_labels    = null
    priming_blacklist   = null

    // ── Outputs ────────────────────────────────────────────────────────────
    outdir = '/scratch/users/fabro/scPolASeq_dengue/results/day1'

    // ── Pipeline mode ──────────────────────────────────────────────────────
    run_mode                   = 'full'
    aligner                    = 'starsolo'
    protocol_mode              = '10x_3p'
    enable_internal_clustering = true
    grouping_levels            = 'cluster,cell_type,sample_condition_celltype'
    skip_uninformative_cell_type_grouping = true

    // ── Coverage ───────────────────────────────────────────────────────────
    emit_group_bams = false
    emit_bigwigs    = true

    // ── APA parameters ─────────────────────────────────────────────────────
    apa_min_coverage                  = 5
    apa_min_pdui_delta                = 0.2
    apa_grouping_levels               = 'cluster,cell_type'
    apa_group_level                   = 'cluster'
    apa_model_type                    = 'random_forest'
    enable_single_cell_apa_projection = false

    // ── MVP toggles ────────────────────────────────────────────────────────
    enable_pas_reference_build   = true
    enable_sierra_quant          = true
    enable_pas_scoring           = false
    enable_scapture              = true
    enable_ml_model              = false

    // ── Resource limits (deepthought: Ryzen 7800X3D, 8c/16t, 124 GiB) ────────
    max_cpus   = 16
    max_memory = '120 GB'
    max_time   = '48 h'
}

process {
    executor = 'local'

    // STAR and genome build occupy the whole machine while running.
    // Nextflow queues the two samples sequentially (16 + 16 > 16).
    // Human genome index loads ~30 GB; extra headroom covers working sets.
    withName: 'PREPARE_REFERENCE_BUNDLE' {
        cpus   = 16
        memory = '96 GB'
        time   = '16 h'
    }

    withName: 'STARSOLO_ALIGN_SC' {
        cpus   = 16
        memory = '96 GB'
        time   = '24 h'
    }

    withLabel: process_high {
        cpus   = 16
        memory = '96 GB'
        time   = '24 h'
    }

    withLabel: process_medium {
        cpus   = 8
        memory = '48 GB'
        time   = '12 h'
    }

    // 5 k cells × 2 samples → larger AnnData than pbmc1k.
    withName: 'SCANPY_CLUSTER_SC' {
        cpus   = 8
        memory = '48 GB'
        time   = '8 h'
    }

    withLabel: process_python {
        cpus   = 8
        memory = '32 GB'
        time   = '8 h'
    }

    withLabel: process_single {
        cpus   = 4
        memory = '16 GB'
        time   = '8 h'
    }

    // Per-cluster jobs — low CPUs per process so Nextflow runs 4 in parallel:
    //   COVERAGE_TRACKS:      4 CPUs × 4 concurrent = 16 CPUs, 4×16 = 64 GB
    //   SIERRA_QUANT:         4 CPUs × 3 concurrent = 12 CPUs, 3×32 = 96 GB
    //   APA_FEATURE_EXTRACTION: 4 CPUs × 4 concurrent = 16 CPUs, 4×24 = 96 GB
    withName: 'COVERAGE_TRACKS' {
        cpus   = 4
        memory = '16 GB'
        time   = '12 h'
    }

    withName: 'SIERRA_QUANT' {
        cpus   = 4
        memory = '32 GB'
        time   = '12 h'
    }

    withName: 'APA_FEATURE_EXTRACTION' {
        cpus   = 4
        memory = '24 GB'
        time   = '8 h'
    }
}
