// conf/apptainer.config
// Enable Apptainer as container engine (Singularity-compatible, rootless).
// Use with: nextflow run main.nf -profile apptainer ...
// Requires: apptainer >= 1.0 and SIF files built via containers/build.sh

apptainer {
    enabled    = true
    autoMounts = true
    cacheDir   = params.containsKey('apptainer_cache_dir') && params.apptainer_cache_dir
                    ? params.apptainer_cache_dir
                    : '/scratch/cache/apptainer'
    runOptions = '--nv'   // GPU passthrough; harmless if GPU not used
}

process.executor = 'local'
