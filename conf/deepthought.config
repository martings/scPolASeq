// ============================================================
// conf/deepthought.config — server-specific profile
// Host  : deepthought (Ubuntu 24.04, AMD Ryzen 7 7800X3D 16T,
//         128 GB RAM, NVIDIA RTX 3080, NVMe /scratch)
// Usage : nextflow run main.nf -profile deepthought [,conda|apptainer] ...
// ============================================================

// ── Directory layout ─────────────────────────────────────────────
// workDir   → /scratch/.nf_work  (set in ~/.nextflow/config)
// SIF cache → /scratch/.nf_work/apptainer/scpolaseq
// Use -work-dir for a named run-specific subdir when you need to -resume.

params {
    // outdir is intentionally NOT set here so per-dataset profiles
    // (e.g. test_pbmc1k_deepthought) can set it without being overridden.
    // If no profile sets outdir, it falls back to the nextflow.config default ('results').

    // Pre-built SIF cache: run  bash containers/build.sh  once to populate
    apptainer_cache_dir = '/scratch/.nf_work/apptainer/scpolaseq'
}

// ── Executor ──────────────────────────────────────────────────────────────────
process.executor = 'local'

executor {
    name   = 'local'
    cpus   = 16
    memory = '120 GB'    // leave ~8 GB headroom
}

// ── Resource labels ───────────────────────────────────────────────────────────
process {
    cpus   = 4
    memory = '16 GB'
    time   = '24 h'

    withLabel: process_single {
        cpus   = 1
        memory = '4 GB'
    }

    withLabel: process_medium {
        cpus   = 4
        memory = '16 GB'
    }

    withLabel: process_high {
        cpus   = 8
        memory = '32 GB'
    }

    withLabel: process_python {
        cpus   = 4
        memory = '16 GB'
    }

    withLabel: process_r {
        cpus   = 2
        memory = '8 GB'
    }

    withLabel: gpu {
        accelerator      = 1
        containerOptions = '--nv'
    }

    withLabel: high_mem {
        memory = '64 GB'
        cpus   = 16
    }

    withLabel: many_cpu {
        cpus   = 16
        memory = '32 GB'
    }
}

// ── Conda ─────────────────────────────────────────────────────────────────────
// Enable with -profile deepthought,conda
// conda env cache lands in the run workDir/conda by default.
// To share caches across runs, set: conda.cacheDir = '/scratch/cache/conda'
conda {
    useMamba = true
}

// ── Apptainer ────────────────────────────────────────────────────────────────
// Enable with -profile deepthought,apptainer (requires container directives in modules)
// Note: do NOT set enabled here — let the global ~/.nextflow/config or -profile apptainer
// manage the engine toggle to avoid declaration-order override issues.
apptainer {
    autoMounts = true
    cacheDir   = '/scratch/cache/apptainer'
    runOptions = '--nv'
}
