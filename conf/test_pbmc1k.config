/*
 * Test profile — PBMC 1k v3 (10x Genomics, healthy donor)
 *
 * Dataset
 *   ~1,000 PBMCs from a healthy donor, Chromium Next GEM Single Cell 3ʹ v3
 *   https://www.10xgenomics.com/resources/datasets/1-k-pbm-cs-from-a-healthy-donor-3-0-0
 *
 * Setup (run once before launching the pipeline):
 *   bash conf/download_pbmc1k.sh /cluster/datasets/pbmc1k
 *
 * Expected paths on QNAP NAS (mounted at /cluster):
 *   FASTQs : /cluster/datasets/pbmc1k/fastqs/
 *   Genome : /cluster/datasets/reference/GRCh38/genome.fa
 *   GTF    : /cluster/datasets/reference/GRCh38/genes.gtf
 *   Whitelist: /cluster/datasets/10x_whitelists/3M-february-2018.txt
 *
 * Launch:
 *   nextflow run main.nf \
 *     -profile test_pbmc1k,singularity \
 *     -c /cluster/projects/nextflow.config
 */
params {

    input            = "${projectDir}/tests/data/samplesheet_pbmc1k.csv"

    // Reference — human GRCh38
    genome_fasta     = '/cluster/datasets/reference/GRCh38/genome.fa'
    gtf              = '/cluster/datasets/reference/GRCh38/genes.gtf'

    // polyA atlas / known sites — set to null if unavailable on first run
    known_polya      = null
    priming_blacklist = null

    // Cell metadata — not pre-supplied for this dataset; internal clustering used
    cell_metadata       = null
    cluster_assignments = null
    cell_type_labels    = null

    outdir = '/cluster/projects/scPolASeq_pbmc1k/results'

    // Pipeline mode
    run_mode                   = 'full'
    aligner                    = 'starsolo'
    protocol_mode              = '10x_3p'
    enable_internal_clustering = true
    grouping_levels            = 'cluster,cell_type'

    // Coverage
    emit_group_bams = false
    emit_bigwigs    = true

    // APA parameters
    apa_min_coverage                  = 5
    apa_min_pdui_delta                = 0.2
    apa_grouping_levels               = 'cluster,cell_type'
    apa_group_level                   = 'cluster'
    apa_model_type                    = 'random_forest'
    enable_single_cell_apa_projection = false

    // Resource limits (match cluster notebook: 12 CPUs, 11 GB RAM)
    max_cpus   = 8
    max_memory = '10 GB'
    max_time   = '12 h'
}

process {
    executor = 'local'

    withLabel: process_high {
        cpus   = 8
        memory = '10 GB'
        time   = '6 h'
    }
    withLabel: process_medium {
        cpus   = 4
        memory = '6 GB'
        time   = '3 h'
    }
    withLabel: process_low {
        cpus   = 2
        memory = '4 GB'
        time   = '1 h'
    }
    withLabel: process_single {
        cpus   = 1
        memory = '2 GB'
        time   = '30 min'
    }
}
