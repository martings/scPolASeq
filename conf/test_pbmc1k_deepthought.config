/*
 * test_pbmc1k_deepthought.config
 *
 * PBMC 1k v3 (10x Genomics, healthy donor) — deepthought paths.
 * Data staged locally on /scratch NVMe for maximum I/O performance.
 *
 * Usage:
 *   nextflow run main.nf \
 *     -profile deepthought,apptainer,test_pbmc1k_deepthought \
 *     -work-dir /scratch/work/scPolASeq_runs/pbmc1k_$(date +%Y%m%d) \
 *     -resume
 */
params {

    // ── Input ──────────────────────────────────────────────────────────────
    input            = '/scratch/data/pbmc1k/samplesheet.csv'

    // ── Reference — GRCh38 (staged from mother NAS) ────────────────────────
    genome_fasta     = '/scratch/data/reference/GRCh38/genome.fa'
    gtf              = '/scratch/data/reference/GRCh38/genes.gtf'   // → gencode.v44.gtf

    // ── polyA atlas (PolyASite 2.0 / GRCh38) ──────────────────────────────
    known_polya      = '/scratch/data/polya_atlas/polyasite2_GRCh38.tsv'

    // ── No pre-supplied cell metadata: internal clustering ─────────────────
    cell_metadata       = null
    cluster_assignments = null
    cell_type_labels    = null
    priming_blacklist   = null

    // ── Outputs ────────────────────────────────────────────────────────────
    outdir = '/scratch/results/scPolASeq/pbmc1k'

    // ── Pipeline mode ──────────────────────────────────────────────────────
    run_mode                   = 'full'
    aligner                    = 'starsolo'
    protocol_mode              = '10x_3p'
    enable_internal_clustering = true
    grouping_levels            = 'cluster,cell_type'

    // ── Coverage ───────────────────────────────────────────────────────────
    emit_group_bams = false
    emit_bigwigs    = true

    // ── APA parameters ─────────────────────────────────────────────────────
    apa_min_coverage                  = 5
    apa_min_pdui_delta                = 0.2
    apa_grouping_levels               = 'cluster,cell_type'
    apa_group_level                   = 'cluster'
    apa_model_type                    = 'random_forest'
    enable_single_cell_apa_projection = false

    // ── Resource limits (deepthought: 16T, 128 GB RAM) ─────────────────────
    max_cpus   = 16
    max_memory = '120 GB'
    max_time   = '24 h'
}

process {
    executor = 'local'

    withLabel: process_high {
        cpus   = 16
        memory = '64 GB'
        time   = '12 h'
    }

    withLabel: process_medium {
        cpus   = 8
        memory = '32 GB'
        time   = '6 h'
    }

    withLabel: process_python {
        cpus   = 8
        memory = '32 GB'
    }

    withLabel: process_single {
        cpus   = 2
        memory = '8 GB'
        time   = '2 h'
    }
}
